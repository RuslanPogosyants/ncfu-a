# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# ОБЯЗАТЕЛЬНО: случайная строка, минимум 32 символа
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-a-real-secret-key

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# База данных
# SQLite (по умолчанию, для разработки):
DATABASE_URL=sqlite:///./university.db
# PostgreSQL (для продакшена):
# DATABASE_URL=postgresql://user:password@localhost:5432/university_db

# Распознавание лиц (порог от 0.0 до 1.0, меньше — строже)
FACE_RECOGNITION_TOLERANCE=0.6
